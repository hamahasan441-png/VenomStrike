# VenomStrike v3.0 — Environment Configuration
# Copy to .env and customize

# Flask Web UI
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Scanning Settings
VS_THREADS=10
VS_TIMEOUT=10
VS_DELAY=0.5
VS_ASYNC=true
VS_MAX_CONCURRENT=50
VS_MIN_CONFIDENCE=70

# Scan depth: quick, standard, deep, full
VS_SCAN_DEPTH=standard

# Database & Reports
VS_DB_PATH=venomstrike.db
VS_REPORTS_DIR=reports

# Tool Integrations
# Nmap (requires nmap installed)
VS_NMAP_ENABLED=false
VS_NMAP_PATH=nmap

# OWASP ZAP (requires ZAP running)
VS_ZAP_ENABLED=false
ZAP_API_KEY=
ZAP_PROXY=http://127.0.0.1:8080

# Nuclei (requires nuclei installed)
VS_NUCLEI_ENABLED=false
VS_NUCLEI_PATH=nuclei
VS_NUCLEI_TEMPLATES=

# Shodan (requires API key from shodan.io)
SHODAN_API_KEY=

# NVD/CVE Lookup (optional API key for higher rate limits)
NVD_API_KEY=
