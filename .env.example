# VenomStrike v10.0 — Environment Configuration
# Copy to .env and customize

# Flask Web UI
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Scanning Settings
VS_THREADS=10
VS_TIMEOUT=10
VS_DELAY=0.5
VS_ASYNC=true
VS_MAX_CONCURRENT=50
VS_MIN_CONFIDENCE=70

# Scan depth: quick, standard, deep, full, quantum, titan, hydra, chimera, phoenix
VS_SCAN_DEPTH=standard

# Database & Reports
VS_DB_PATH=venomstrike.db
VS_REPORTS_DIR=reports

# Phoenix v10.0 settings
VS_PARAM_DEDUP=true
VS_CONTEXT_VALIDATION=true
VS_PAYLOAD_MINIMIZER=true
VS_IMPACT_ANALYSIS=true
VS_SCAN_PROFILER=true

# Chimera v9.0 settings
VS_ADAPTIVE_RATE_LIMIT=true
VS_VULN_CORRELATION=true
VS_SCAN_OPTIMIZATION=true
VS_SARIF_OUTPUT=false
VS_PARAM_TAMPERING=true

# Hydra v8.0 settings
VS_SMART_PAYLOAD=true
VS_ATTACK_CHAIN=true
VS_BAYESIAN_SCORING=true
VS_RESPONSE_INTELLIGENCE=true

# Titan v7.0 settings
VS_OOB_CALLBACK_DOMAIN=
VS_PAYLOAD_MUTATION=true
VS_ROBUST_TIMING=true
VS_WAF_FINGERPRINT=true

# Tool Integrations
# Nmap (requires nmap installed)
VS_NMAP_ENABLED=false
VS_NMAP_PATH=nmap

# OWASP ZAP (requires ZAP running)
VS_ZAP_ENABLED=false
ZAP_API_KEY=
ZAP_PROXY=http://127.0.0.1:8080

# Nuclei (requires nuclei installed)
VS_NUCLEI_ENABLED=false
VS_NUCLEI_PATH=nuclei
VS_NUCLEI_TEMPLATES=

# Shodan (requires API key from shodan.io)
SHODAN_API_KEY=

# NVD/CVE Lookup (optional API key for higher rate limits)
NVD_API_KEY=
